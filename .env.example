# Free Model Orchestrator — runtime configuration.
# Copy to `.env` (gitignored) for local dev, or install as the systemd
# EnvironmentFile in production. NEVER commit a filled-in copy.
#
# Production storage (matches ORACLE_FRESH_SERVER_DEPLOY.md):
#   - File:    /opt/apps/free-model-orchestrator/.env
#   - Owner:   the service user, mode 0600 (root:root or <svc>:<svc>)
#   - Source:  provisioned from Agent Vault, never checked into git
#   - Wiring:  systemd unit `EnvironmentFile=/opt/apps/free-model-orchestrator/.env`
#
# Local dev: keep this file as `.env` beside the package and `source` it, or
# export the vars in your shell before running the CLI.

# --- Secrets ---------------------------------------------------------------
# Bearer token for the OmniRoute management/OpenAI-compatible API.
OMNIROUTE_API_KEY=

# --- OmniRoute -------------------------------------------------------------
OMNIROUTE_URL=https://omniroute.internal

# --- Database --------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/fmo

# --- Hermes inventory ------------------------------------------------------
# Mode: filesystem | command | http
HERMES_INVENTORY_MODE=filesystem
HERMES_INVENTORY_CRON=0 3 * * *

# filesystem mode
HERMES_HOME=
HERMES_AGENTS_PATH=
HERMES_ROUTINES_PATH=

# command mode
# HERMES_INVENTORY_COMMAND=

# http mode
# HERMES_INVENTORY_URL=
