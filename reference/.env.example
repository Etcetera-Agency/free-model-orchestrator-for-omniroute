# Runtime
ENVIRONMENT=production
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgresql://user:password@postgres:5432/free_model_orchestrator

# OmniRoute
OMNIROUTE_URL=http://127.0.0.1:20128
OMNIROUTE_API_KEY=
OMNIROUTE_REQUEST_TIMEOUT_MS=30000

# Quota research search — OmniRoute built-in POST /v1/search (same OMNIROUTE_URL
# + API key), fixed to gemini-grounded-search. Configure the Gemini credentials
# in the OmniRoute dashboard.
OMNIROUTE_SEARCH_PATH=/v1/search
GEMINI_GROUNDED_SEARCH_MODEL=gemini-2.5-flash

# Hermes inventory adapter: filesystem | command | http
HERMES_INVENTORY_MODE=filesystem

# Daily inventory
HERMES_INVENTORY_CRON=0 4 * * *
HERMES_INVENTORY_TIMEZONE=Europe/Bucharest
HERMES_UNKNOWN_ROLE_TRIGGER=true

# Filesystem mode
HERMES_HOME=/home/hermes/.hermes
HERMES_AGENTS_PATH=/opt/hermes/agents
HERMES_ROUTINES_PATH=/opt/hermes/routines
HERMES_CRON_JOBS_PATH=/home/hermes/.hermes/cron/jobs.json
HERMES_STATE_DB_PATH=/home/hermes/.hermes/state.db

# Command mode
HERMES_INVENTORY_COMMAND=
HERMES_INVENTORY_COMMAND_TIMEOUT_MS=60000

# HTTP mode
HERMES_INVENTORY_URL=
HERMES_INVENTORY_TOKEN=
HERMES_INVENTORY_TIMEOUT_MS=30000

# Artificial Analysis
ARTIFICIAL_ANALYSIS_API_KEY=
ARTIFICIAL_ANALYSIS_BASE_URL=https://artificialanalysis.ai
